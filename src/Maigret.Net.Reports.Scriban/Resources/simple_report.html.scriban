<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ username }} — Maigret.Net username search report</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        body { padding: 1.5rem 0; }
        .table td, .table th { padding: 0.4rem; }
        .card { margin-bottom: 1rem; }
        .id-key { width: 30%; word-break: break-word; }
        @media print { .pagebreak { page-break-before: always; } }
    </style>
</head>
<body>
<div class="container">

    <div class="card">
        <div class="card-body">
            <h4 class="card-title mb-1">Username search report for {{ username }}</h4>
            <small class="text-muted">
                Generated by <a href="https://github.com/totpero/Maigret.Net">Maigret.Net</a> at {{ generated_at }}
                ({{ total_checked }} sites checked, <strong>{{ total_found }}</strong> found)
            </small>
        </div>
    </div>

    {{ if tag_summary != null && tag_summary.size > 0 }}
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Website tags</h5>
            <p class="mb-0">
                {{ for entry in tag_summary }}
                <span class="badge bg-secondary">{{ entry.key }} <span class="text-light">({{ entry.value }})</span></span>
                {{ end }}
            </p>
        </div>
    </div>
    {{ end }}

    {{ if country_summary != null && country_summary.size > 0 }}
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Geo tags</h5>
            <p class="mb-0">
                {{ for entry in country_summary }}
                <span class="badge bg-info text-dark">{{ entry.key }} <span class="text-muted">({{ entry.value }})</span></span>
                {{ end }}
            </p>
        </div>
    </div>
    {{ end }}

    {{ if accounts.size == 0 }}
    <div class="card">
        <div class="card-body">
            <em>No claimed accounts found.</em>
        </div>
    </div>
    {{ else }}
    {{ for account in accounts }}
    <div class="card">
        <div class="card-body">
            <h3 class="mb-1">
                <a class="text-dark" href="{{ account.url_main }}" target="_blank" rel="noopener">{{ account.site_name }}</a>
            </h3>
            {{ if account.tags != null && account.tags.size > 0 }}
            <div class="text-muted small mb-2">Tags: {{ account.tags | array.join ", " }}</div>
            {{ end }}
            <p class="card-text">
                <a href="{{ account.profile_url }}" target="_blank" rel="noopener">{{ account.profile_url }}</a>
            </p>
            {{ if account.ids != null && account.ids.size > 0 }}
            <table class="table table-striped table-sm">
                <tbody>
                {{ for id in account.ids }}
                <tr>
                    <th class="id-key">{{ id.key }}</th>
                    <td>{{ id.value }}</td>
                </tr>
                {{ end }}
                </tbody>
            </table>
            {{ end }}
        </div>
    </div>
    {{ end }}
    {{ end }}

</div>
</body>
</html>
