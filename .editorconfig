# EditorConfig for Maigret.Net — aligned with the Aviva Solutions C# Coding Guidelines
# (https://github.com/dennisdoomen/CSharpGuidelines).
# Severity: error = Must · warning = Should · suggestion = May.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
max_line_length = 130

[*.{xml,csproj,props,targets,slnx,nuspec}]
indent_size = 2

[*.{yml,yaml,json,scriban}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# C# language conventions
# -----------------------------------------------------------------------------

[*.cs]

# AV2201 — use language types (string/int/object) instead of CLR aliases
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access            = true:error

# AV1500/AV1525/AV1535/AV1545 — modern, intention-revealing patterns
csharp_prefer_braces                          = true:warning
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_inlined_variable_declaration     = true:warning
csharp_style_throw_expression                 = true:suggestion

# AV1520 — `var` only when the type is evident
csharp_style_var_for_built_in_types  = false:suggestion
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere            = false:suggestion

# AV1502/AV1547 — readable boolean expressions
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return     = true:suggestion

# AV1500 — small methods favour expression bodies for one-liners
csharp_style_expression_bodied_methods    = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:warning
csharp_style_expression_bodied_accessors  = when_on_single_line:warning
csharp_style_expression_bodied_lambdas    = when_on_single_line:warning

# AV1130 — prefer immutable collection accessors / readonly fields
dotnet_style_readonly_field = true:error

# AV1501 — restrict accessibility
dotnet_style_require_accessibility_modifiers = always:warning

# AV1100 — auto-properties when nothing else is needed
dotnet_style_prefer_auto_properties = true:warning

# AV1500 — deconstruction & switch-expressions to keep methods short
csharp_style_deconstructed_variable_declaration = true:suggestion
csharp_style_prefer_switch_expression           = true:suggestion

# AV2400 — modern using directives
csharp_using_directive_placement = outside_namespace:warning
csharp_style_namespace_declarations = file_scoped:warning

# AV1535 — always block scope on if/else/for/foreach/using/while
csharp_prefer_simple_using_statement = true:suggestion

# AV2407 — no #region
dotnet_diagnostic.IDE0066.severity = warning   # use switch expression
dotnet_diagnostic.IDE0290.severity = suggestion # primary constructor

# Async naming + ConfigureAwait (AV1755 / AV1835) are enforced manually + reviews.

# -----------------------------------------------------------------------------
# Roslyn analyzer severities (Microsoft.CodeAnalysis.NetAnalyzers)
# -----------------------------------------------------------------------------

# CA1001 — types owning IDisposable fields should implement IDisposable
dotnet_diagnostic.CA1001.severity = error
# CA1051 — no public instance fields
dotnet_diagnostic.CA1051.severity = error
# CA1062 — validate public-method arguments
dotnet_diagnostic.CA1062.severity = warning
# CA1304/CA1305/CA1310 — culture-aware string ops
dotnet_diagnostic.CA1304.severity = warning
dotnet_diagnostic.CA1305.severity = warning
dotnet_diagnostic.CA1310.severity = warning
# CA1822 — mark members static when they don't access instance state
dotnet_diagnostic.CA1822.severity = suggestion
# CA2007 — ConfigureAwait(false) in library code (AV1835)
dotnet_diagnostic.CA2007.severity = warning
# CA2016 — propagate CancellationToken
dotnet_diagnostic.CA2016.severity = warning

# Performance / micro-optimization rules with marginal value here:
# CA1848 — LoggerMessage delegates are noisy; AV doesn't require them
dotnet_diagnostic.CA1848.severity = none
# CA1873 — log-message argument-evaluation cost (paired with CA1848)
dotnet_diagnostic.CA1873.severity = none
# CA1859 — concrete return types (we prefer abstract returns per AV1130)
dotnet_diagnostic.CA1859.severity = none
# CA5359 — TLS callback returning true is intentional: Maigret follows aiohttp's
# default of probing sites with broken / expired certs. Site-checking results
# are still classified through Status, not trust chains. Suppressed in code.
dotnet_diagnostic.CA5359.severity = none
